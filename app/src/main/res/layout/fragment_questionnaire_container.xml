<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.authentication.fragments.QuestionnaireContainerFragment">

    <me.relex.circleindicator.CircleIndicator3
        android:id="@+id/ciQuestionnaire"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:ci_height="10dp"
        app:ci_width="45dp"
        app:ci_margin="15dp"
        android:layout_marginTop="50dp"
        app:ci_drawable="@drawable/ic_auth_dot_active"
        app:ci_drawable_unselected="@drawable/ic_auth_dot_inactive"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vpQuestionnaire"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ciQuestionnaire" />


</androidx.constraintlayout.widget.ConstraintLayout>