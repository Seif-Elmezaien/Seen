<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_graph"
    app:startDestination="@id/homeEntryFragment">
    <fragment
        android:id="@+id/homeEntryFragment"
        android:name="com.example.seen.ui.home.fragment.HomeEntryFragment"
        android:label="fragment_home_entry"
        tools:layout="@layout/fragment_home_entry" >
        <action
            android:id="@+id/action_homeEntryFragment_to_onboardingContainerFragment"
            app:destination="@id/onboardingContainerFragment" />
        <action
            android:id="@+id/action_homeEntryFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeEntryFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/onboardingContainerFragment"
        android:name="com.example.seen.ui.home.fragment.OnboardingContainerFragment"
        android:label="fragment_onboarding_container"
        tools:layout="@layout/fragment_onboarding_container" >
        <action
            android:id="@+id/action_onboardingContainerFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/onboardingContainerFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.seen.ui.home.fragment.HomeFragment"
        android:label="HomeFragment" />
</navigation>